rules_version = '2';

// Reglas de seguridad de Firestore para FOCUS. (v2 — con validación de esquema)
// Equivalente a "RLS": cada usuario solo puede tocar sus propios datos,
// aunque tenga la apiKey (que es pública por diseño en toda app Firebase).
// Además, valida la FORMA de los datos compartidos (posts, chats, mensajes)
// para que nadie pueda guardar campos extra, textos desmedidos o URLs que
// no sean imágenes reales (defensa en profundidad contra XSS almacenado).
//
// Cómo desplegarlas: Firebase console > Firestore Database > Rules >
// pega este contenido entero y pulsa "Publish".

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Solo aceptamos como imagen lo que genera la propia app (data:image/...)
    // o una URL https. Nunca javascript:, texto suelto, etc.
    function isImageUrl(v) {
      return v is string && v.size() < 1048000
        && (v.matches('data:image/.*') || v.matches('https://.*'));
    }

    // =====================================================
    // users/{uid} — documento principal (hábitos, timeSpent, email...)
    //
    // - Escribir/borrar: solo el dueño.
    // - Leer: cualquier usuario autenticado. Necesario porque
    //   findUserByEmail() hace una query sobre la colección users
    //   para invitar a gente a los chats. Si más adelante quieres
    //   que los hábitos sean 100% privados, mueve el email a una
    //   colección "profiles" pública y restringe users a solo dueño.
    // =====================================================
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(uid);

      // Subcolecciones privadas del usuario: fotos diarias, memories,
      // guardados, reposts espejo, etc. Solo el dueño, lectura incluida.
      match /{subcollection}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // =====================================================
    // posts/{postId} — feed social compartido
    // =====================================================
    match /posts/{postId} {

      function validBook(b) {
        return b.keys().hasOnly(['workKey', 'title', 'author', 'year', 'coverId'])
          && b.title is string && b.title.size() <= 300
          && (!('author' in b) || b.author == null
              || (b.author is string && b.author.size() <= 200))
          && (!('workKey' in b) || b.workKey == null
              || (b.workKey is string && b.workKey.size() <= 100))
          && (!('year' in b) || b.year == null || b.year is int
              || (b.year is string && b.year.size() <= 8))
          && (!('coverId' in b) || b.coverId == null || b.coverId is int
              || (b.coverId is string && b.coverId.size() <= 20));
      }

      function validNewPost(d) {
        return d.keys().hasOnly(['authorId', 'authorName', 'authorAvatar',
              'text', 'image', 'book', 'likesCount', 'repostsCount', 'createdAt'])
          && d.authorId == request.auth.uid
          && d.authorName is string
          && d.authorName.size() > 0 && d.authorName.size() <= 60
          && (d.authorAvatar == null || isImageUrl(d.authorAvatar))
          && d.text is string && d.text.size() <= 500
          && (d.image == null || isImageUrl(d.image))
          && (d.book == null || validBook(d.book))
          && d.likesCount == 0 && d.repostsCount == 0;
      }

      // Un contador solo puede moverse de uno en uno (es lo que hace
      // increment(±1) en toggleLike/toggleRepost). Así nadie puede
      // inflar likes con un solo update.
      function counterOk(f) {
        return request.resource.data.get(f, 0) is int
          && resource.data.get(f, 0) is int
          && (request.resource.data.get(f, 0) - resource.data.get(f, 0)) >= -1
          && (request.resource.data.get(f, 0) - resource.data.get(f, 0)) <= 1;
      }

      allow read: if signedIn();

      // Crear: solo si firmas el post con tu propio uid y con la forma exacta
      // que genera createPost().
      allow create: if signedIn() && validNewPost(request.resource.data);

      // Actualizar: SOLO los contadores de likes/reposts, de uno en uno.
      // La app nunca edita el contenido de un post ya publicado, así que
      // cerrarlo del todo impide colar contenido malicioso a posteriori.
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likesCount', 'repostsCount'])
        && counterOk('likesCount')
        && counterOk('repostsCount');

      allow delete: if signedIn()
        && resource.data.authorId == request.auth.uid;

      // Cada usuario solo puede crear/borrar SU propio like/repost,
      // y el documento solo lleva la marca de tiempo.
      match /likes/{uid} {
        allow read: if signedIn();
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['createdAt']);
        allow delete: if isOwner(uid);
      }
      match /reposts/{uid} {
        allow read: if signedIn();
        allow create, update: if isOwner(uid)
          && request.resource.data.keys().hasOnly(['createdAt']);
        allow delete: if isOwner(uid);
      }
    }

    // =====================================================
    // chats/{chatId} — grupos privados entre miembros
    // =====================================================
    match /chats/{chatId} {
      function isMember() {
        return signedIn() && request.auth.uid in resource.data.members;
      }

      // Leer: solo miembros (cubre también la query array-contains)
      allow read: if isMember();

      // Crear: cualquier usuario autenticado, siempre que se incluya
      // a sí mismo como miembro y creador, con la forma de createChat().
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['name', 'members', 'avatar',
             'createdBy', 'createdAt', 'lastMessage', 'lastMessageAt'])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() <= 100
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && (request.resource.data.avatar == null
            || isImageUrl(request.resource.data.avatar))
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 2000;

      // Actualizar: solo miembros, y solo los campos que usa la app
      // (invitar gente, avatar, lastMessage). Los miembros solo pueden
      // AÑADIRSE (hasAll: la lista nueva contiene a todos los antiguos),
      // así nadie puede echar a otros de un chat.
      allow update: if isMember()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['name', 'members', 'avatar', 'lastMessage', 'lastMessageAt'])
        && request.resource.data.members is list
        && request.resource.data.members.size() <= 100
        && request.resource.data.members.hasAll(resource.data.members)
        && (!('name' in request.resource.data)
            || (request.resource.data.name is string
                && request.resource.data.name.size() <= 60))
        && (!('avatar' in request.resource.data)
            || request.resource.data.avatar == null
            || isImageUrl(request.resource.data.avatar))
        && (!('lastMessage' in request.resource.data)
            || (request.resource.data.lastMessage is string
                && request.resource.data.lastMessage.size() <= 2000));

      // Borrar: solo quien creó el chat
      allow delete: if signedIn()
        && resource.data.createdBy == request.auth.uid;

      // Mensajes: solo miembros del chat padre pueden leer/escribir,
      // cada mensaje va firmado con el uid real del remitente y con
      // la forma exacta que genera sendMessage().
      match /messages/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        allow read: if signedIn()
          && request.auth.uid in parentChat().members;
        allow create: if signedIn()
          && request.auth.uid in parentChat().members
          && request.resource.data.keys().hasOnly(['senderId', 'senderName',
               'senderAvatar', 'text', 'createdAt'])
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && (!('senderName' in request.resource.data)
              || (request.resource.data.senderName is string
                  && request.resource.data.senderName.size() <= 60))
          && (!('senderAvatar' in request.resource.data)
              || request.resource.data.senderAvatar == null
              || isImageUrl(request.resource.data.senderAvatar));
        // Los mensajes no se editan ni se borran desde la app
        allow update, delete: if false;
      }
    }

    // Todo lo que no esté listado arriba: denegado por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
